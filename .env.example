# ============================================================
# AI Ad Assistant — 环境变量配置
# 复制此文件为 .env.local 并填入真实值
# cp .env.example .env.local
# ============================================================

# ──────────────────────────────────────
# Supabase（数据库 + 认证）
# ──────────────────────────────────────

# Supabase 项目 URL
# 获取：Supabase Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase 匿名密钥（客户端安全，可公开）
# 获取：Supabase Dashboard → Settings → API → anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxx

# Supabase Service Role 密钥（仅服务端使用，绝不暴露到客户端）
# 获取：Supabase Dashboard → Settings → API → service_role key
# 注意：此密钥拥有数据库完全访问权限，切勿提交到 Git
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxx

# ──────────────────────────────────────
# AI 分析（OpenAI / DeepSeek）
# ──────────────────────────────────────

# OpenAI API Key
# 获取：https://platform.openai.com/api-keys
# 如果使用 DeepSeek，填入 DeepSeek API Key
# 获取：https://platform.deepseek.com/api_keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API Base URL（默认 OpenAI，DeepSeek 填下方地址）
# OpenAI 默认：留空即可
# DeepSeek：https://api.deepseek.com/v1
OPENAI_BASE_URL=https://api.deepseek.com/v1

# 模型名称
# OpenAI：gpt-4o / gpt-4o-mini
# DeepSeek：deepseek-chat
OPENAI_MODEL=deepseek-chat

# ──────────────────────────────────────
# 支付宝支付
# ──────────────────────────────────────

# 支付宝应用 ID
# 获取：支付宝开放平台 → 我的应用 → APPID
ALIPAY_APP_ID=2021xxxxxxxxxxxx

# 应用私钥（PKCS8 格式，一行，不含头尾）
# 生成：支付宝开放平台 → 密钥管理 → 应用私钥
ALIPAY_PRIVATE_KEY=MIIEvQIBADANBgkqhkiG9w0BAQ...

# 支付宝公钥
# 获取：支付宝开放平台 → 密钥管理 → 支付宝公钥
ALIPAY_PUBLIC_KEY=MIIBIjANBgkqhkiG9w0BAQ...

# 支付宝网关
# 生产环境：https://openapi.alipay.com/gateway.do
# 沙箱环境：https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# ──────────────────────────────────────
# 应用配置
# ──────────────────────────────────────

# 站点地址（开发环境用 localhost，生产用 https://wqaihub.cn）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 应用名称
NEXT_PUBLIC_APP_NAME=AI Ad Assistant

# ──────────────────────────────────────
# 安全（可选）
# ──────────────────────────────────────

# JWT 签名密钥（用于自定义 Token 签发）
# 生成：openssl rand -base64 64
JWT_SECRET=your_jwt_secret_here_generate_with_openssl
